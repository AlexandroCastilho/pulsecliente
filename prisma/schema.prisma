generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Empresa {
  id         String      @id @default(uuid())
  nome       String
  slug       String      @unique
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  pesquisas  Pesquisa[]
  smtpConfig SmtpConfig?
  usuarios   Usuario[]

  @@map("empresas")
}

model Usuario {
  id           String        @id
  email        String        @unique
  nome         String
  role         Role          @default(MEMBER)
  ativo        Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  empresaId    String
  notificacoes Notificacao[]
  empresa      Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("usuarios")
}

model Pesquisa {
  id        String     @id @default(uuid())
  titulo    String
  descricao String?
  ativa     Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  empresaId String
  envios    Envio[]
  perguntas Pergunta[]
  empresa   Empresa    @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("pesquisas")
}

model Pergunta {
  id          String       @id @default(uuid())
  titulo      String
  tipo        TipoPergunta
  opcoes      Json?
  obrigatoria Boolean      @default(true)
  ordem       Int          @default(0)
  pesquisaId  String
  pesquisa    Pesquisa     @relation(fields: [pesquisaId], references: [id], onDelete: Cascade)

  @@map("perguntas")
}

model Envio {
  id                String      @id @default(uuid())
  emailDestinatario String
  nomeDestinatario  String?
  status            StatusEnvio @default(PENDENTE)
  token             String      @unique
  jobId             String?
  erroLog           String?
  createdAt         DateTime    @default(now())
  enviadoEm         DateTime?
  pesquisaId        String
  pesquisa          Pesquisa    @relation(fields: [pesquisaId], references: [id], onDelete: Cascade)
  resposta          Resposta?

  @@unique([pesquisaId, emailDestinatario])
  @@map("envios")
}

model Resposta {
  id           String   @id @default(uuid())
  dados        Json
  respondidoEm DateTime @default(now())
  envioId      String   @unique
  envio        Envio    @relation(fields: [envioId], references: [id], onDelete: Cascade)

  @@map("respostas")
}

model SmtpConfig {
  id        String   @id @default(uuid())
  host      String
  port      Int      @default(587)
  user      String
  pass      String
  fromName  String
  fromEmail String
  empresaId String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  empresa   Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("smtp_configs")
}

model Notificacao {
  id        String   @id @default(uuid())
  titulo    String
  mensagem  String
  lida      Boolean  @default(false)
  tipo      String   @default("SISTEMA")
  createdAt DateTime @default(now())
  usuarioId String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("notificacoes")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum StatusEnvio {
  PENDENTE
  PROCESSANDO
  ENVIADO
  ERRO
  RESPONDIDO
  EXPIRADO
}

enum TipoPergunta {
  TEXTO_LIVRE
  MULTIPLA_ESCOLHA
  ESCALA_NPS
  ESTRELAS
}
